---
layout: home.njk
title: InTransit
description: Smarter Metro Mobility for India.
permalink: /
---
<div class="home">
  <!-- Transit-Style Hero -->
  <section class="hero-transit">
    <div class="container">
      <h1>The Best iOS App for<br><strong>Indian Metro Transit</strong></h1>
      <p>No more fusses, just easy commutes. Get real-time updates, accessibility guidance, and beautiful maps for every major metro in India.</p>
      <div class="cta-badge">
        <a href="https://apps.apple.com/us/app/intransit/id6756531079" target="_blank">
          <img src="/assets/images/appstore.svg" alt="Download on the App Store" style="height: 56px;">
        </a>
      </div>
      <div id="hero">
        {% for i in [4, 2, 1, 3, 5] %}
        <picture id="hero_{{ i }}">
           <source media="(max-width: 600px)" 
            srcset="/assets/images/home/hero_{{ i }}-400w.webp 1x, /assets/images/home/hero_{{ i }}-800w.webp 2x, /assets/images/home/hero_{{ i }}-1600w.webp 3x"
            type="image/webp"/>
          <source media="(min-width: 601px) and (max-width: 800px)" 
            srcset="/assets/images/home/hero_{{ i }}-800w.webp 1x, /assets/images/home/hero_{{ i }}-1600w.webp 2x, /assets/images/home/hero_{{ i }}@3x.webp 3x"
            type="image/webp"/>
          <source media="(max-width: 600px)" 
            srcset="/assets/images/home/hero_{{ i }}-400w.png 1x, /assets/images/home/hero_{{ i }}-800w.png 2x, /assets/images/home/hero_{{ i }}-1600w.png 3x"
            type="image/png"/>
          <source media="(min-width: 601px) and (max-width: 800px)" 
            srcset="/assets/images/home/hero_{{ i }}-800w.png 1x, /assets/images/home/hero_{{ i }}-1600w.png 2x, /assets/images/home/hero_{{ i }}@3x.png 3x"
            type="image/png"/>
          <source type="image/webp" 
            srcset="/assets/images/home/hero_{{ i }}.webp 1x, /assets/images/home/hero_{{ i }}@2x.webp 2x, /assets/images/home/hero_{{ i }}@3x.webp 3x">
          <img src="/assets/images/home/hero_{{ i }}.png" 
            srcset="/assets/images/home/hero_{{ i }}@2x.png 2x, /assets/images/home/hero_{{ i }}@3x.png 3x"
            alt="InTransit App Screenshot {{ i }}" 
            loading="eager"
            width="{% if i == 1 %}320{% elseif i == 2 or i == 3 %}294{% else %}272{% endif %}" 
            height="{% if i == 1 %}655{% elseif i == 2 or i == 3 %}600{% else %}560{% endif %}">
        </picture>
        {% endfor %}
      </div>
    </div>
  </section>

  <div class="container">
    <div class="section-heading">
      <h2>Let InTransit Take Your Hand</h2>
      <p>Everything you need for a smooth journey, right in your pocket and on your wrist</p>
    </div>

    <!-- Features Grid -->
    <div class="flex columns" id="features">
      <article class="feature-card" id="live-activities">
        <h2>Live Activities</h2>
        <p>Visually stunning updates bring next stop, interchange, and ETA information right to your Home Screen and Dynamic Island. Never miss your stop again.</p>
        <div id="lva-grid" class="grid">
          <picture>
            <source type="image/webp" 
            srcset="/assets/images/home/lv-1.webp 1x, /assets/images/home/lv-1@2x.webp 2x, /assets/images/home/lv-1@3x.webp 3x">
            <img src="/assets/images/home/lv-1.png" 
            srcset="/assets/images/home/lv-1@2x.png 2x, /assets/images/home/lv-1@3x.png 3x"
            alt="Live Activity for the Kalyani Nagar to PCMC route in Pune region" 
            loading="lazy"
            width="395" 
            height="184">
            <p class="timer" data-interval="1958">32:38</p>
          </picture>

          <picture>
            <source type="image/webp" 
            srcset="/assets/images/home/lv-2.webp 1x, /assets/images/home/lv-2@2x.webp 2x, /assets/images/home/lv-2@3x.webp 3x">
            <img src="/assets/images/home/lv-2.png" 
            srcset="/assets/images/home/lv-2@2x.png 2x, /assets/images/home/lv-2@3x.png 3x"
            alt="Live Activity for the Jangpura to Paratap Nagar route in New Delhi region" 
            loading="lazy"
            width="395" 
            height="184">
            <p class="timer" data-interval="1452">24:12</p>
          </picture>

          <picture>
            <source type="image/webp" 
            srcset="/assets/images/home/lv-3.webp 1x, /assets/images/home/lv-3@2x.webp 2x, /assets/images/home/lv-3@3x.webp 3x">
            <img src="/assets/images/home/lv-3.png" 
            srcset="/assets/images/home/lv-3@2x.png 2x, /assets/images/home/lv-3@3x.png 3x"
            alt="Live Activity for the Cubbon Park to Silk Institute route in Bengaluru region" 
            loading="lazy"
            width="395" 
            height="184">
            <p class="timer" data-interval="2525">42:05</p>
          </picture>

          <picture>
            <source type="image/webp" 
            srcset="/assets/images/home/lv-4.webp 1x, /assets/images/home/lv-4@2x.webp 2x, /assets/images/home/lv-4@3x.webp 3x">
            <img src="/assets/images/home/lv-4.png" 
            srcset="/assets/images/home/lv-4@2x.png 2x, /assets/images/home/lv-4@3x.png 3x"
            alt="Live Activity for the Thirumangalam to Wimco Naagr route in Chennai region" 
            loading="lazy"
            width="395" 
            height="184">
            <p class="timer" data-interval="442">7:22</p>
          </picture>
        </div>
      </article>

      <article class="feature-card ltr">
        <picture>
          <source type="image/webp" 
          srcset="/assets/images/home/a11y-codes.webp 1x, /assets/images/home/a11y-codes@2x.webp 2x, /assets/images/home/a11y-codes@3x.webp 3x">
          <img src="/assets/images/home/a11y-codes.png" 
          srcset="/assets/images/home/a11y-codes@2x.png 2x, /assets/images/home/a11y-codes@3x.png 3x"
          alt="Accessibility availability labels displayed for the Kalyani Nagar station in Pune region" 
          loading="lazy"
          width="157" 
          height="320"/>
        </picture>
        <div class="content">
          <h2>Accessibility First</h2>
          <p>Navigate with confidence. Get detailed guidance on elevators, ramps, and platform access, making metro travel truly inclusive for everyone.</p>
        </div>
      </article>

      <article class="feature-card ltr">
        <picture>
          <source type="image/webp" 
          srcset="/assets/images/home/offline.webp 1x, /assets/images/home/offline@2x.webp 2x, /assets/images/home/offline@3x.webp 3x">
          <img src="/assets/images/home/offline.png" 
          srcset="/assets/images/home/offline@2x.png 2x, /assets/images/home/offline@3x.png 3x"
          alt="Accessibility availability labels displayed for the Kalyani Nagar station in Pune region" 
          loading="lazy"
          width="157" 
          height="320"/>
        </picture>
        <div class="content">
          <h2>Reliable Offline</h2>
          <p>Access high-quality maps and essential route information even when you're deep underground with zero signal. Built for the reality of metro transit.</p>
        </div>
      </article>
    </div>

    <!-- Regions Section -->
    <section id="regions" style="margin-bottom: 6rem; text-align: center;">
      <div class="section-heading">
        <h2>7 Cities & Counting…</h2>
        <p>Covering the heart of India's urban mobility.</p>
      </div>
      <p style="font-size: 1.5rem; font-weight: 500; line-height: 1.6; color: var(--text-1);">
        Ahmedabad • Bengaluru • Chennai • Kolkata • Mumbai • New Delhi • Pune
      </p>
      <p style="margin-top: 1.5rem; color: var(--text-3);">Each city supports all active and under-construction lines. We map them before they even open.</p>
    </section>

    <!-- Privacy & Made In India Grid -->
    <div class="flex columns">
      <article class="feature-card">
        <h2>Private by Design</h2>
        <p>Your data is not our business. We never collect information that can identify you. No tracking, just transit.</p>
        <p style="margin-top: 1rem;"><a href="{{ "/privacy" | absolute_url }}" class="cta-secondary">View Privacy Policy</a></p>
      </article>

      <article class="feature-card">
        <h2>Made for India</h2>
        <p>Built with pride in India, for the unique challenges of Indian commuters. Full support for local languages in every city we serve.</p>
      </article>
    </div>

    <!-- Final CTA -->
    <section id="download">
      <picture id="cta-bg">
        <source type="image/webp" 
        srcset="/assets/images/home/cta-bg.webp 1x, /assets/images/home/cta-bg@2x.webp 2x, /assets/images/home/cta-bg@3x.webp 3x">
        <img src="/assets/images/home/cta-bg.png" 
        srcset="/assets/images/home/cta-bg@2x.png 2x, /assets/images/home/cta-bg@3x.png 3x"
        alt="InTransit track and location graphics" 
        loading="lazy"
        width="402" 
        height="424">
      </picture>
      <div id="cta-content">
        <h2>Ready to go?</h2>
        <p style="margin-bottom: 2rem; font-size: 1.25rem;">Join thousands of commuters enjoying a smarter way to travel.</p>
        <div class="cta-badge">
          <a href="https://apps.apple.com/us/app/intransit/id6756531079" target="_blank">
            <img src="/assets/images/appstore.svg" alt="Download on the App Store" style="height: 56px;">
          </a>
        </div>
        <p class="questions">Questions? <a href="mailto:support@intransit.app">I'm here to help.</a></p>
      </div>
    </section>
  </div>
</div>
