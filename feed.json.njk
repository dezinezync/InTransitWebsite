---
permalink: /feed.json
eleventyExcludeFromCollections: true
metadata:
  title: InTransit Blog
  subtitle: Smarter Metro Mobility for India
  language: en
  url: https://intransit.app/
  author:
    name: Nikhil Nigade
    email: support@intransit.app
---
{
  "version": "https://jsonfeed.org/version/1.1",
  "title": "{{ metadata.title }}",
  "home_page_url": "{{ metadata.url }}",
  "feed_url": "{{ site.url }}/feed.json",
  "description": "{{ metadata.subtitle | jsonify }}",
  "icon": "{{ "/assets/images/appicon/appicon@2x.png" | absolute_url }}",
  "author": {
    "name": "Nikhil Nigade",
    "url": "https://social.dezinezync.com/@nikhil",
    "avatar": "https://www.gravatar.com/avatar/884e476f05a20d0af1d8de59b946dbcf"
  },
  "language": "en-IN",
  "hubs": [{
    "type": "WebSub",
    "url": "https://websubhub.com/hub"
  }],
  "items": [
    {%- for post in collections.posts %}
    {%- set absolutePostUrl = post.url | absolute_url %}
    {
      "id": "{{ absolutePostUrl }}",
      "url": "{{ absolutePostUrl }}",
      "title": "{{ post.data.title }}",
      "content_html": "{% if post.templateContent %}{{ post.templateContent | htmlToAbsoluteUrls(absolutePostUrl) | jsonify }}{% else %}""{% endif %}",
      "date_published": "{{ post.date | dateToRfc3339 }}"
      {%- if post.data.bannerImage -%}
      ,"banner_image": "{{ (post.data.bannerImage + '-1600w.png') | absolute_url }}"
      {%- elseif post.data.bannerImageWebP -%}
      ,"banner_image": "{{ (post.data.bannerImageWebP + '-1600w.png') | absolute_url }}"
      {%- endif -%}
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
