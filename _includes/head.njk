<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
{% if title %}
  <title>{{ title }} - {{ site.title }}</title>
{% else %}
  <title>{{ site.title }}</title>
  <meta property="og:title" content="{{ site.title }}" />
{% endif %}
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="supported-color-schemes" content="light dark">
  <link rel="icon" type="image/png" href="{{ "/assets/images/favicon.png" | absolute_url }}">
  <link rel="stylesheet" href="{{ "/assets/css/style.css" | absolute_url }}">
  <link rel="alternate" title="{{ site.title }}" type="application/rss+xml" href="{{ "/feed.xml"  | absolute_url}}"/>
  <link rel="alternate" title="{{ site.title }}" type="application/json" href="{{ "/feed.json" | absolute_url }}" />
  <meta name="apple-itunes-app" content="app-id=6756531079, app-argument=https://apps.apple.com/us/app/intransit/id6756531079"/>
{% if title %}
  <meta property="og:title" content="{{ title }} - {{ site.title }}" />
{% endif %}
{% if excerpt %}
  <meta name="description" content="{{ excerpt | markdown | strip_html | strip }}">
  <meta property="og:description" content="{{ excerpt | markdown | strip_html | strip }}" />
  <meta property="og:type" content="article" />
{% elseif page.description %}
  <meta name="description" content="{{ page.description }}">
  <meta property="og:description" content="{{ page.description }}" />
  <meta property="og:type" content="website" />
{% else %}
  <meta name="description" content="{{ site.description }}">
  <meta property="og:description" content="{{ site.description }}" />
  <meta property="og:type" content="website" />
{% endif %}
{% if page.bannerImage %}
  <meta property="og:image" content="{{ [page.bannerImage, '@2x.png'] | join | absolute_url  }}" />
{% elseif post.bannerImage %}
  <meta property="og:image" content="{{ [post.bannerImage, '@2x.png'] | join | absolute_url }}" />
{% else %}
  <meta property="og:image" content="{{ "/assets/images/hero-1600w.webp" | absolute_url }}" />
{% endif %}
  <meta property="og:locale" content="en-IN" />
  <meta property="og:site_name" content="InTransit" />
  <meta property="og:url" content="{{ page.url | absolute_url }}"/>
  <link rel="me" href="https://social.dezinezync.com/@intransit"/>
  <link rel="icon" sizes="180x180" href="{{ "/assets/images/appicon/apple-touch-icon-180x180.png" | absolute_url }}" />
  <link rel="apple-touch-icon" sizes="180x180" href="{{ "/assets/images/appicon/apple-touch-icon-180x180.png" | absolute_url }}" />
  <link rel="apple-touch-icon" sizes="152x152" href="{{ "/assets/images/appicon/apple-touch-icon-152x152.png" | absolute_url }}" />
  <link rel="apple-touch-icon" sizes="76x76" href="{{ "/assets/images/appicon/apple-touch-icon-76x76.png" | absolute_url }}" />
  <link rel="apple-touch-icon" sizes="60x60" href="{{ "/assets/images/appicon/apple-touch-icon-60x60.png" | absolute_url }}" />
  <link rel="apple-touch-icon" href="{{ "/assets/images/appicon/apple-touch-icon.png" | absolute_url }}" />
{% if page.keywords %}
  <meta name="keywords" content="{{ page.keywords }}">
{% elseif post.categories %}
  <meta name="keywords" content="{{ post.categories }}">
{% else %}
  <meta name="keywords" content="{{ site.keywords }}">
{% endif %}
{% if site.brandColor %}
  <style id="brand-color">
    :root {
      --dz-brand-color: {{ site.brandColor }};
    }
  </style>
{% endif %}
</head>